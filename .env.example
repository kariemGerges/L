# Copy to .env.local and fill in values (never commit .env.local)
# https://nextjs.org/docs/app/guides/environment-variables

# ─── Public ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Email (required for booking submissions) ────────────────────────────────
# Sign up at https://resend.com — free tier works for testing
RESEND_API_KEY=re_xxxxxxxx
BOOKING_NOTIFICATION_EMAIL=lumeevent2026@gmail.com
EMAIL_FROM=Lumé Events <onboarding@resend.dev>

# ─── Security ─────────────────────────────────────────────────────────────────
# Recommended in production — used to hash client IPs for rate limiting
# RATE_LIMIT_SALT=replace-with-a-long-random-string
